[Unit]
Description=Limespaces supervisor
After=network.target

[Service]
User=limespaces
WorkingDirectory=/home/limespaces
Environment=DISPLAY=:1
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
ExecStart=/usr/share/bin/limespaces-supervisor
Restart=on-failure

[Install]
WantedBy=multi-user.target